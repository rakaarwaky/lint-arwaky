{
  "name": "lint-arwaky-graph",
  "displayName": "Lint Arwaky Graph Visualizer",
  "description": "Visualizes dependency and import graphs for Classes, Functions, and Interfaces/Traits in Lint Arwaky.",
  "version": "1.10.13",
  "publisher": "rakaarwaky",
  "repository": {
    "type": "git",
    "url": "https://github.com/rakaarwaky/lint-arwaky.git"
  },
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Visualization",
    "Other"
  ],
  "activationEvents": [],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "lint-arwaky-graph.show",
        "title": "Lint Arwaky: Show Code Graph"
      },
      {
        "command": "lint-arwaky-graph.refresh",
        "title": "Refresh Graph",
        "icon": "$(refresh)"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "lint-arwaky-explorer",
          "title": "Lint Arwaky Explorer",
          "icon": "$(graph)"
        }
      ]
    },
    "views": {
      "lint-arwaky-explorer": [
        {
          "type": "webview",
          "id": "lint-arwaky.graphView",
          "name": "Dependency Graph"
        }
      ]
    },
    "menus": {
      "editor/title": [
        {
          "command": "lint-arwaky-graph.show",
          "group": "navigation"
        }
      ],
      "view/title": [
        {
          "command": "lint-arwaky-graph.refresh",
          "when": "view == lint-arwaky.graphView",
          "group": "navigation"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "package": "npx vsce package"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.90.0",
    "@vscode/vsce": "^3.9.1",
    "typescript": "^5.0.0"
  }
}
