{
  "$schema": "https://mimo.xiaomi.com/mimocode/config.json",
  "default_agent": "build",
  "autoupdate": "notify",
  "share": "auto",
  "provider": {
    "anthropic": {
      "options": {
        "timeout": 600000,
        "setCacheKey": true
      }
    },
    "openai": {
      "options": {
        "timeout": 300000
      }
    }
  },
  "server": {
    "port": 4096,
    "hostname": "0.0.0.0",
    "mdns": false
  },
  "permission": {
    "*": "allow",
    "bash": {
      "*": "allow",
      "cargo *": "allow",
      "cargo build *": "allow",
      "cargo check *": "allow",
      "cargo test *": "allow",
      "cargo fmt *": "allow",
      "cargo clippy *": "allow",
      "cargo run *": "allow",
      "git *": "allow",
      "git status *": "allow",
      "git diff *": "allow",
      "git log *": "allow",
      "git add *": "allow",
      "git commit *": "allow",
      "git push *": "allow",
      "git checkout *": "allow",
      "git branch *": "allow",
      "ls *": "allow",
      "cat *": "allow",
      "head *": "allow",
      "tail *": "allow",
      "grep *": "allow",
      "find *": "allow",
      "mkdir *": "allow",
      "rm *": "deny",
      "rm -rf *": "deny",
      "sudo *": "deny",
      "curl *": "allow",
      "wget *": "allow"
    },
    "edit": "allow",
    "read": {
      "*": "allow",
      "*.env": "deny",
      "*.env.*": "deny",
      "*.env.example": "allow",
      "*.env.local": "deny"
    },
    "write": "allow",
    "webfetch": "allow",
    "websearch": "allow",
    "external_directory": {
      "~/projects/*": "allow",
      "~/*": "allow"
    },
    "skill": {
      "*": "allow"
    },
    "doom_loop": "ask"
  },
  "agent": {
    "build": {
      "description": "Default development agent with full tool access",
      "mode": "primary",
      "model": "OmniRouter/high-availability",
      "temperature": 0.3,
      "permission": {
        "bash": {
          "*": "allow",
          "cargo *": "allow",
          "git *": "allow"
        }
      }
    },
    "plan": {
      "description": "Read-only analysis and planning agent",
      "mode": "primary",
      "model": "OmniRouter/high-availability",
      "temperature": 0.1,
      "permission": {
        "edit": "deny",
        "write": "deny",
        "bash": "deny"
      }
    },
    "compose": {
      "description": "Workflow-driven agent with built-in skills",
      "mode": "primary",
      "model": "OmniRouter/high-availability",
      "temperature": 0.3
    },
    "general": {
      "description": "General-purpose multi-step worker",
      "mode": "subagent",
      "model": "OmniRouter/high-availability",
      "temperature": 0.3
    },
    "explore": {
      "description": "Fast read-only codebase explorer",
      "mode": "subagent",
      "model": "OmniRouter/high-availability",
      "temperature": 0.1,
      "permission": {
        "edit": "deny",
        "write": "deny",
        "bash": "deny"
      }
    }
  },
  "compaction": {
    "auto": true,
    "prune": true,
    "tail_turns": 3,
    "reserved": 15000
  },
  "watcher": {
    "ignore": [
      "target/**",
      "dist/**",
      "node_modules/**",
      ".git/**",
      "*.lock",
      "log/**",
      "*.log"
    ]
  },
  "command": {
    "build": {
      "template": "Build the entire workspace with release profile",
      "description": "Build all crates in release mode",
      "agent": "build"
    },
    "test": {
      "template": "Run all workspace tests",
      "description": "Run cargo test --workspace",
      "agent": "build"
    },
    "lint": {
      "template": "Run clippy on all targets with warnings as errors",
      "description": "Run cargo clippy --all-targets -- -D warnings",
      "agent": "build"
    },
    "fmt": {
      "template": "Format all code with rustfmt",
      "description": "Run cargo fmt --all",
      "agent": "build"
    },
    "check": {
      "template": "Run cargo check on the workspace",
      "description": "Quick type and borrow check",
      "agent": "build"
    },
    "scan": {
      "template": "Run the lint-arwaky CLI to scan the current project",
      "description": "Self-lint with lint-arwaky",
      "agent": "build"
    },
    "release": {
      "template": "Build release, run tests, and prepare for deployment",
      "description": "Full release pipeline",
      "agent": "build"
    }
  },
  "skills": {
    "paths": [".agents/skills", ".mimocode/skills"]
  },
  "instructions": [
    "AGENTS.md",
    "ARCHITECTURE.md",
    "CONTRIBUTING.md",
    "TEST.md"
  ],
  "formatter": {
    "rustfmt": {
      "command": ["cargo", "fmt", "--all"],
      "extensions": [".rs"]
    }
  },
  "snapshot": true,
  "checkpoint": {
    "thresholds": ["40%", "60%", "80%"],
    "reserved": 10000,
    "push_caps": {
      "max_per_session": 10
    }
  },
  "logLevel": "INFO"
}
