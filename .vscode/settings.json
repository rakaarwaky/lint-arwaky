{
  "rust-analyzer.check.extraArgs": ["--lib", "--bins"],
  "rust-analyzer.check.command": "check",
  "rust-analyzer.diagnostics.enabled": true,
  "rust-analyzer.exclude": [
    "**/tests",
    "**/test-workspaces",
    "**/tests/**"
  ],
  "files.exclude": {
    "**/tests": true,
    "**/test-workspaces": true
  },
  "files.watcherExclude": {
    "**/tests/**": true,
    "**/test-workspaces/**": true
  }
}
