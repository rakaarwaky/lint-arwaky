#!/usr/bin/env bash
# Lint Arwaky Pre-Commit Hook — multi-gate quality checks
#
# Gates:
#   1. AES Architecture Compliance (lint-arwaky check)
#   2. Rust Clippy (no warnings)
#   3. Rust Tests (all pass)
#   4. Commit Message (conventional commits)
#   5. TODO/FIXME detection (src/ only, skip test/ and test-workspaces/)
#   6. AES Scan Coverage (test-workspaces must detect >= 24 unique AES codes)
#
# Block commit on first failure.

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
REPO_ROOT="$(dirname "$(dirname "$SCRIPT_DIR")")"
LOCAL_BIN="$REPO_ROOT/target/release/lint-arwaky-cli"

if [ -x "$LOCAL_BIN" ]; then
    LINT_CMD="$LOCAL_BIN"
else
    LINT_CMD="lint-arwaky-cli"
fi

FAILED=0
GATE_NUM=0

fail() {
    local gate="$1" reason="$2"
    FAILED=1
    echo ""
    echo "❌ Gate $GATE_NUM ($gate) FAILED: $reason"
    echo "   Commit blocked."
}

# ─── Gate 1: AES Architecture Compliance ─────────────────────────────
GATE_NUM=1
echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
echo "  Gate $GATE_NUM: AES Architecture Compliance"
echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
"$LINT_CMD" check "$REPO_ROOT" 2>&1 || fail "AES Check" "Architecture violations found"
if [ $FAILED -eq 0 ]; then
    echo "✅ Gate $GATE_NUM passed."
fi

# ─── Gate 2: Rust Clippy (no warnings) ─────────────────────────────────
GATE_NUM=2
echo ""
echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
echo "  Gate $GATE_NUM: Rust Clippy (no warnings)"
echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
if cargo clippy --all-targets -- -D warnings 2>&1; then
    echo "✅ Gate $GATE_NUM passed."
else
    fail "Clippy" "Rust warnings/errors detected"
fi

# ─── Gate 3: Rust Tests ────────────────────────────────────────────────
GATE_NUM=3
echo ""
echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
echo "  Gate $GATE_NUM: Rust Tests"
echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
if cargo test --workspace 2>&1; then
    echo "✅ Gate $GATE_NUM passed."
else
    fail "Tests" "Some tests failed"
fi

# ─── Gate 4: TODO/FIXME Detection (src/ only) ─────────────────────────
GATE_NUM=4
echo ""
echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
echo "  Gate $GATE_NUM: TODO/FIXME Detection (src/ only)"
echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"

# Search only in src/ directories, exclude test/ and test-workspaces/
# Only match TODO/FIXME in comments (lines starting with //), not in string literals
TODO_FILES=$(find "$REPO_ROOT/crates" -type f \( -name "*.rs" -o -name "*.py" -o -name "*.js" -o -name "*.ts" \) \
    -path "*/src/*" \
    ! -path "*/test*" \
    ! -path "*/test-workspaces/*" \
    -exec grep -l -E '^\s*//.*\b(TODO|FIXME|XXX|HACK|BUG)\b' {} + 2>/dev/null || true)

if [ -n "$TODO_FILES" ]; then
    fail "TODO/FIXME" "Found markers in source comments:"
    echo ""
    echo "   Files with TODO/FIXME in src/ (excluding tests):"
    echo "$TODO_FILES" | while read -r f; do
        echo "     $f"
        grep -n -E '^\s*//.*\b(TODO|FIXME|XXX|HACK|BUG)\b' "$f" | sed 's/^/       /'
    done
    echo ""
    echo "   Remove or resolve these markers before committing."
    echo "   (Markers in test/ and test-workspaces/ are allowed.)"
else
    echo "✅ Gate $GATE_NUM passed — no TODO/FIXME in src/ comments."
fi

# ─── Gate 5: AES Scan Coverage (per-workspace) ──────────────────────
GATE_NUM=5
echo ""
echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
echo "  Gate $GATE_NUM: AES Scan Coverage (per-workspace)"
echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
MIN_AES_CODES=24
ALL_PASS=true
SCAN_PATHS=(
  "$REPO_ROOT/test-workspaces/crates"
  "$REPO_ROOT/test-workspaces/modules"
  "$REPO_ROOT/test-workspaces/packages"
)
for SP in "${SCAN_PATHS[@]}"; do
  SCAN_OUTPUT=$("$LINT_CMD" scan "$SP" 2>&1) || true
  UNIQUE_AES=$(echo "$SCAN_OUTPUT" | grep -oP 'Total Unique AES Codes:\s*\K[0-9]+' || echo "0")
  NAME=$(basename "$SP")
  if [ "$UNIQUE_AES" -lt "$MIN_AES_CODES" ]; then
    fail "AES Scan ($NAME)" "Only $UNIQUE_AES unique AES codes detected (minimum: $MIN_AES_CODES)"
    ALL_PASS=false
  else
    echo "  ✅ $NAME: $UNIQUE_AES unique AES codes"
  fi
done
if [ "$ALL_PASS" = true ]; then
  echo "✅ Gate $GATE_NUM passed."
else
  echo ""
  echo "  Each workspace must detect at least $MIN_AES_CODES unique AES violation codes."
fi

# ─── Final Verdict ─────────────────────────────────────────────────────
echo ""
echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
if [ $FAILED -eq 0 ]; then
    echo "✅ All gates passed — commit allowed."
    exit 0
else
    echo "❌ One or more gates failed — commit BLOCKED."
    echo ""
    echo "   Tip: Run 'cargo clippy --all-targets -- -D warnings' and"
    echo "        'cargo test --workspace' manually to debug locally."
    exit 1
fi
