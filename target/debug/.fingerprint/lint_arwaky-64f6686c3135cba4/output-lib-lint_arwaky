t\nyou no longer need to derive from `Super<Self>`.\n"},"level":"error","spans":[{"file_name":"src-rust/surfaces/mcp_tools_command.rs","byte_start":299,"byte_end":328,"line_start":10,"line_end":10,"column_start":20,"column_end":49,"is_primary":true,"text":[{"text":"    container: Arc<dyn ServiceContainerAggregate>,","highlight_start":20,"highlight_end":49}],"label":"`service_container_aggregate::ServiceContainerAggregate` is not dyn compatible","suggested_replacement":null,"suggestion_applicability":null,"expansion":null}],"children":[{"message":"for a trait to be dyn compatible it needs to allow building a vtable\nfor more information, visit <https://doc.rust-lang.org/reference/items/traits.html#dyn-compatibility>","code":null,"level":"note","spans":[{"file_name":"src-rust/contract/service_container_aggregate.rs","byte_start":25,"byte_end":50,"line_start":3,"line_end":3,"column_start":11,"column_end":36,"is_primary":false,"text":[{"text":"pub trait ServiceContainerAggregate: Send + Sync {","highlight_start":11,"highlight_end":36}],"label":"this trait is not dyn compatible...","suggested_replacement":null,"suggestion_applicability":null,"expansion":null},{"file_name":"src-rust/contract/service_container_aggregate.rs","byte_start":73,"byte_end":76,"line_start":4,"line_end":4,"column_start":8,"column_end":11,"is_primary":true,"text":[{"text":"    fn get<T: 'static>(&self) -> Option<&T>;","highlight_start":8,"highlight_end":11}],"label":"...because method `get` has generic type parameters","suggested_replacement":null,"suggestion_applicability":null,"expansion":null}],"children":[],"rendered":null},{"message":"consider moving `get` to another trait","code":null,"level":"help","spans":[],"children":[],"rendered":null},{"message":"the following types implement `service_container_aggregate::ServiceContainerAggregate`:\n  agent::adapter_mixin_container::AdapterMixinContainer\n  agent::agent_container_registry::StubContainer\n  agent::capability_mixin_container::CapabilityM