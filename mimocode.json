{
  "$schema": "https://mimo.xiaomi.com/mimocode/config.json",
  // ===========================
  // MODEL CONFIGURATION
  // ===========================
  "model": "OmniRouter/high-availability",
  "small_model": "OmniRouter/high-availability",
  // ===========================
  // DEFAULT AGENT
  // ===========================
  "default_agent": "build",
  // ===========================
  // AUTO-UPDATE & SHARING
  // ===========================
  "autoupdate": "notify",
  "share": "auto",
  // ===========================
  // PROVIDER CONFIGURATION
  // ===========================
  "provider": {
    "anthropic": {
      "options": {
        "timeout": 600000,
        "setCacheKey": true
      }
    },
    "openai": {
      "options": {
        "timeout": 300000
      }
    }
  },
  // Disabled providers (uncomment to disable)
  // "disabled_providers": ["openai", "gemini"],
  // ===========================
  // SERVER CONFIGURATION
  // ===========================
  "server": {
    "port": 4096,
    "hostname": "0.0.0.0",
    "mdns": false
  },
  // ===========================
  // PERMISSIONS
  // ===========================
  // Default: most tools allowed, bash needs approval
  "permission": {
    "*": "allow",
    "bash": {
      "*": "ask",
      "cargo *": "allow",
      "cargo build *": "allow",
      "cargo check *": "allow",
      "cargo test *": "allow",
      "cargo fmt *": "allow",
      "cargo clippy *": "allow",
      "cargo run *": "allow",
      "git *": "allow",
      "git status *": "allow",
      "git diff *": "allow",
      "git log *": "allow",
      "git add *": "allow",
      "git commit *": "ask",
      "git push *": "ask",
      "git checkout *": "ask",
      "git branch *": "ask",
      "ls *": "allow",
      "cat *": "allow",
      "head *": "allow",
      "tail *": "allow",
      "grep *": "allow",
      "find *": "allow",
      "mkdir *": "allow",
      "rm *": "deny",
      "rm -rf *": "deny",
      "sudo *": "deny",
      "curl *": "ask",
      "wget *": "ask"
    },
    "edit": "allow",
    "read": {
      "*": "allow",
      "*.env": "deny",
      "*.env.*": "deny",
      "*.env.example": "allow",
      "*.env.local": "deny"
    },
    "write": "allow",
    "webfetch": "allow",
    "websearch": "allow",
    "external_directory": {
      "~/projects/*": "allow",
      "~/*": "ask"
    },
    "skill": {
      "*": "allow"
    },
    "doom_loop": "ask"
  },
  // ===========================
  // AGENT CONFIGURATION
  // ===========================
  "agent": {
    "build": {
      "description": "Default development agent with full tool access",
      "mode": "primary",
      "model": "OmniRouter/high-availability",
      "temperature": 0.3,
      "permission": {
        "bash": {
          "*": "ask",
          "cargo *": "allow",
          "git *": "allow"
        }
      }
    },
    "plan": {
      "description": "Read-only analysis and planning agent",
      "mode": "primary",
      "model": "OmniRouter/high-availability",
      "temperature": 0.1,
      "permission": {
        "edit": "deny",
        "write": "deny",
        "bash": "deny"
      }
    },
    "compose": {
      "description": "Workflow-driven agent with built-in skills",
      "mode": "primary",
      "model": "OmniRouter/high-availability",
      "temperature": 0.3
    },
    "general": {
      "description": "General-purpose multi-step worker",
      "mode": "subagent",
      "model": "OmniRouter/high-availability",
      "temperature": 0.3
    },
    "explore": {
      "description": "Fast read-only codebase explorer",
      "mode": "subagent",
      "model": "OmniRouter/high-availability",
      "temperature": 0.1,
      "permission": {
        "edit": "deny",
        "write": "deny",
        "bash": "deny"
      }
    },
    // Custom agents for this project
    "rust-reviewer": {
      "description": "Reviews Rust code for AES compliance and best practices",
      "mode": "subagent",
      "model": "OmniRouter/high-availability",
      "temperature": 0.1,
      "permission": {
        "edit": "deny",
        "write": "deny",
        "bash": {
          "*": "deny",
          "cargo clippy *": "allow",
          "cargo check *": "allow"
        }
      }
    },
    "test-runner": {
      "description": "Runs tests and reports results",
      "mode": "subagent",
      "model": "OmniRouter/high-availability",
      "temperature": 0.1,
      "permission": {
        "edit": "deny",
        "write": "deny",
        "bash": {
          "*": "deny",
          "cargo test *": "allow",
          "cargo run *": "allow"
        }
      }
    },
    "security-auditor": {
      "description": "Performs security audits on Rust code",
      "mode": "subagent",
      "model": "OmniRouter/high-availability",
      "temperature": 0.1,
      "permission": {
        "edit": "deny",
        "write": "deny",
        "bash": {
          "*": "deny",
          "cargo audit *": "allow",
          "cargo deny *": "allow"
        }
      }
    }
  },
  // ===========================
  // COMPACTION SETTINGS
  // ===========================
  "compaction": {
    "auto": true,
    "prune": true,
    "tail_turns": 3,
    "reserved": 15000
  },
  // ===========================
  // WATCHER SETTINGS
  // ===========================
  "watcher": {
    "ignore": [
      "target/**",
      "dist/**",
      "node_modules/**",
      ".git/**",
      "*.lock",
      "log/**",
      "*.log"
    ]
  },
  // ===========================
  // CUSTOM COMMANDS
  // ===========================
  "command": {
    "build": {
      "template": "Build the entire workspace with release profile",
      "description": "Build all crates in release mode",
      "agent": "build"
    },
    "test": {
      "template": "Run all workspace tests",
      "description": "Run cargo test --workspace",
      "agent": "build"
    },
    "lint": {
      "template": "Run clippy on all targets with warnings as errors",
      "description": "Run cargo clippy --all-targets -- -D warnings",
      "agent": "build"
    },
    "fmt": {
      "template": "Format all code with rustfmt",
      "description": "Run cargo fmt --all",
      "agent": "build"
    },
    "check": {
      "template": "Run cargo check on the workspace",
      "description": "Quick type and borrow check",
      "agent": "build"
    },
    "scan": {
      "template": "Run the lint-arwaky CLI to scan the current project",
      "description": "Self-lint with lint-arwaky",
      "agent": "build"
    },
    "release": {
      "template": "Build release, run tests, and prepare for deployment",
      "description": "Full release pipeline",
      "agent": "build"
    }
  },
  // ===========================
  // SKILLS CONFIGURATION
  // ===========================
  "skills": {
    "paths": [".agents/skills", ".mimocode/skills"]
  },
  // ===========================
  // INSTRUCTIONS
  // ===========================
  // Additional instruction files to load
  "instructions": [
    "AGENTS.md",
    "ARCHITECTURE.md",
    "CONTRIBUTING.md",
    "TEST.md"
  ],
  // ===========================
  // FORMATTER
  // ===========================
  "formatter": {
    "rustfmt": {
      "command": ["cargo", "fmt", "--all"],
      "extensions": [".rs"]
    }
  },
  // ===========================
  // SNAPSHOT
  // ===========================
  "snapshot": true,
  // ===========================
  // CHECKPOINT
  // ===========================
  "checkpoint": {
    "thresholds": {
      "token_budget": 100000,
      "message_count": 50
    },
    "reserved": 10000,
    "push_caps": {
      "max_per_session": 10
    }
  },
  // ===========================
  // LOG LEVEL
  // ===========================
  "logLevel": "INFO"
}
